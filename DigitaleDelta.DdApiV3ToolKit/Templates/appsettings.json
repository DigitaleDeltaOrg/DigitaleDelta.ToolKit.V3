{
  "Version": "1.0.0",
  "API-Version": "3.0.1",
  "API-Deprecation-Date": "2027-01-01",
  "API-End-of-Life-Date": "2028-01-01",
  "API-Next-Release": "2027-01-01",
  "API-Additional-Documentation": "https://extrainfo",
  "Organisation": "Voorbeeld",
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://localhost:5000"
      },
      "Https": {
        "Url": "https://localhost:5001"
      }
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Error"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "***"
  },
  "DatabaseEngine": "Postgres",
  "ParameterPrefix": "@",
  "TokenSecret": "***",
  "TokenAlgorithm": "HMACSHA256",
  "Cors": {
    "AllowedOrigins": "*"
  },
  "MaxBodySize": 10000000,
  "RateLimiting": {
    "Policies": [
      {
        "Name": "ObservationController",
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "PartitionKey": "api_key"
      },
      {
        "Name": "ReferenceController",
        "PermitLimit": 3,
        "WindowSeconds": 60,
        "PartitionKey": "sub"
      }
    ]
  },
  "PluginSettings": {
    "PluginDirectory": "Plugins"
  },
  "ControllerAuthorization": {
    "ObservationController": {
      "AuthenticationType": "XApiKey",
      "AuthorisationHandler": "DigitaleDelta.DdApiV3ToolKit.ExamplePlugin.ExampleAuthorizationHandler, DigitaleDelta.DdApiV3ToolKit.ExamplePlugin"
    },
    "ReferenceController": {
      "AuthenticationType": "None"
    }
  },
  "ContextDefinitions": "https://raw.githubusercontent.com/DigitaleDeltaOrg/DD-API-V3-ReSpec/refs/heads/main/definitions/ContextDefinitions.csv",
  "MetadataDefinitions": "https://raw.githubusercontent.com/DigitaleDeltaOrg/DD-API-V3-ReSpec/refs/heads/main/definitions/MetadataDefinitions.csv",
  "ReferenceDefinitions": "https://raw.githubusercontent.com/DigitaleDeltaOrg/DD-API-V3-ReSpec/refs/heads/main/definitions/ReferenceDefinitions.csv",
  "GeometryPrecision": {
    "Default": 6,
    "PerSrid": {
      "28992": 1,
      "25831": 1,
      "3035": 1,
      "27700": 1,
      "3857": 1,
      "4258": 6,
      "4326": 6
    }
  }
}
