        "SqlFunctionFormat": "{0} LIKE {1} ESCAPE '\\'",
        "ExpectedArgumentTypes": ["string", "string"],
        "WildCardPosition": "Right",
        "WildCardSymbol": "%",
        "ReturnType": ""
      },
      {
        "ODataFunctionName": "endswith",
        "SqlFunctionFormat": "{0} LIKE {1} ESCAPE '\\'",
        "ExpectedArgumentTypes": ["string", "string"],
        "WildCardPosition": "Left",
        "WildCardSymbol": "%",
        "ReturnType": ""
      },
      {
